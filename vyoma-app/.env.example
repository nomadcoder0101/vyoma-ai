# Vyoma AI app environment

# Optional for local prototype. Required for real AI answers.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.4-mini in the app.
OPENAI_MODEL=gpt-5.4-mini

# Used by deployment docs and future auth/database integrations.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# local keeps the current JSON/Markdown prototype.
# postgres is reserved until repository adapters are implemented.
VYOMA_STORAGE_MODE=local

# Future production settings.
# AUTH_SECRET=
# DATABASE_URL=
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
