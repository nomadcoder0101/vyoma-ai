# Vyoma AI app environment

# Optional for local prototype. Required for real AI answers.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.4-mini in the app.
OPENAI_MODEL=gpt-5.4-mini

# Used by deployment docs and auth/database integrations.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Required for Clerk authentication.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Use postgres for the deployed runtime. Local file mode remains available for backup/import workflows.
VYOMA_STORAGE_MODE=postgres

# Required before storing real OAuth tokens.
INTEGRATION_ENCRYPTION_KEY=

# Required for Postgres runtime. Never commit real database credentials.
DATABASE_URL=
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
